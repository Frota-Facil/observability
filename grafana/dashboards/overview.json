{
  "uid": "sif-overview",
  "title": "Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "APIs online",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(up{project=\"sif\"})", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests per second",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{project=\"sif\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket{project=\"sif\"}[5m])))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "5xx error rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total{project=\"sif\",status=~\"5..\"}[5m])) / sum by (service) (rate(http_requests_total{project=\"sif\"}[5m]))", "legendFormat": "{{service}}", "refId": "A" }
      ]
    }
  ]
}
