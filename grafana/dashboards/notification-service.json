{
  "uid": "sif-notification-service",
  "title": "Notification Service",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Availability",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "up{project=\"sif\",service=\"notification-service\"}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests per second",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": false
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max", "mean"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{project=\"sif\",service=\"notification-service\"}[$__rate_interval]))",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "expr": "sum by (status) (rate(http_requests_total{project=\"sif\",service=\"notification-service\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests in last 5m",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0
        }
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{project=\"sif\",service=\"notification-service\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{project=\"sif\",service=\"notification-service\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Runtime memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{project=\"sif\",service=\"notification-service\"}",
          "legendFormat": "memory",
          "refId": "A"
        }
      ]
    }
  ]
}
